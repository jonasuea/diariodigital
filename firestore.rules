rules_version = '2';
// ATENÇÃO: Este arquivo é uma cópia do master (educafacil/firestore.rules).
// Todos os projetos compartilham o mesmo projeto Firebase e portanto as mesmas regras.
// Sempre sincronize com o master ao fazer alterações.
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // 1. FUNÇÕES AUXILIARES GERAIS
    // =========================================================================
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function getRole() {
      return exists(/databases/$(database)/documents/user_roles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.get('role', 'none')
        : 'none';
    }

    // =========================================================================
    // 2. FUNÇÕES DE PERFIL (PAPÉIS/ROLES)
    // =========================================================================
    // Definição clara de quem é quem dentro do sistema
    function isAdmin()       { return getRole() == 'admin'; }
    function isGestor()      { return getRole() == 'gestor'; }
    function isSecretario()  { return getRole() == 'secretario'; }
    function isProfessor()   { return getRole() == 'professor'; }
    function isEstudante()   { return getRole() == 'aluno' || getRole() == 'estudante'; }
    function isResponsavel() { return getRole() == 'responsavel'; }

    // REGRA DE TRANSIÇÃO: Permitir acesso a qualquer usuário autenticado.
    // Quando você for habilitar as permissões por perfil, basta trocar
    // o "hasAnyRole()" pelas funções acima em cada respectiva coleção.
    function hasAnyRole() {
      return isSignedIn(); 
    }

    // =========================================================================
    // 3. REGRAS POR COLEÇÃO 
    // (Atualmente liberando Leitura e Escrita para todos os logados)
    // =========================================================================

    // ✅ SEGURANÇA: leitura restrita ao próprio usuário ou admin/gestor
    match /user_roles/{uid} {
      allow read: if isAdmin() || isGestor() || request.auth.uid == uid;
      allow create: if (isSignedIn() && request.auth.uid == uid && request.resource.data.get('role', 'pending') == 'pending') || isAdmin() || isGestor();
      // Admin e Gestor podem alterar tudo; o próprio usuário pode apenas atualizar 'role' e 'escola_id'
      // (necessário para o sistema de multi-perfil — sincroniza o perfil ativo com as Security Rules)
      allow update: if isAdmin() || isGestor() ||
        (isSignedIn() && request.auth.uid == uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'escola_id', 'escola_ids']));
      allow delete: if isAdmin() || isGestor();
    }

    match /profiles/{uid} {
      allow read: if isSignedIn();
      // O próprio usuário sempre pode escrever no seu perfil (curto-circuito — não chama getRole())
      allow write: if request.auth.uid == uid || isAdmin() || isGestor() || isSecretario();
      
      match /mensagens_vistas/{messageId} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    match /escolas/{id} {
      allow read: if isSignedIn(); // Qualquer pessoa logada no sistema pode saber os nomes/dados das escolas
    	allow write: if isAdmin() || isGestor(); // Apenas cargos de gestão podem criar ou alterar dados da escola
    }

    match /estudantes/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario();
    }

    match /professores/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario();
    }

    // ✅ EQUIPE GESTORA
    match /equipe_gestora/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario();
    }

    match /turmas/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario();
    }

    match /notas/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }
    
    match /frequencias/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /entradas_diario/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /notas_parciais/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /notas_parciais_config/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /activity_log/{id} {
      // Admin, Gestor, Pedagogo e Secretário podem ler os logs
      allow read: if isAdmin() || isGestor() || isSecretario() || getRole() == 'pedagogo';
      
      // Qualquer usuário autenticado pode criar entradas de log (professor, pedagogo, etc.)
      allow create: if isSignedIn();
      
      // Ninguém pode editar ou excluir logs — apenas direto no banco de dados
      allow update, delete: if false;
    }

    match /eventos/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /maintenance_status/{id} {
      // TODOS os usuários do mundo precisam conseguir LER para saber se o sistema está em manutenção
      allow read: if true; 
      
      // Mas APENAS o Administrador pode LIGAR (escrever) o modo de manutenção
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /objetos_conhecimento/{id} { 
      // Admin, Gestor, Secretário e Professor podem ver as turmas
      allow read: if isAdmin() || isGestor() || isSecretario() || isProfessor();
      
      // Mas só Admin, Gestor, Secretário e Professor podem salvar dados nelas
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /dias_letivos/{id} { 
      // Todos podem ver os dias letivos
      allow read: if hasAnyRole();
      
      // Mas só Admin, Gestor e Secretário podem salvar dados neles
      allow write: if isAdmin() || isGestor() || isSecretario();
    }

    match /horarios/{id} { 
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /registros_aulas/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /avaliacoes/{id} { 
      // Admin, Gestor, Secretário e Professor podem ver as turmas
      allow read: if isAdmin() || isGestor() || isSecretario() || isProfessor();
      
      // Mas só Admin, Gestor, Secretário e Professor podem salvar dados nelas
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /avaliacoes_infantil/{id} { 
      allow read: if isAdmin() || isGestor() || isSecretario() || isProfessor();
      allow write: if isAdmin() || isGestor() || isSecretario() || isProfessor();
    }

    match /manual-uso/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor();
    }

    // ✅ SEGURANÇA: famílias criam (formulário de matrícula), somente gestão lê/edita/deleta
    match /pre_matriculas/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin() || isGestor() || isSecretario();
    }

    match /base_curricular/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario();
    }
    match /mensagens/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isGestor() || isSecretario() || isProfessor() ||
                    (isSignedIn() && resource.data.tipo == 'direta' && 
                     (request.auth.uid == resource.data.destinatario_id || request.auth.token.email == resource.data.get('destinatario_email', '')) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lido', 'data_leitura']));
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.remetente_id);
    }
    
    // ✅ SEGURANÇA: contadores só podem ser alterados pela gestão
    match /counters/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGestor() || isSecretario();
    }
    
    match /logs/{id} {
      allow read: if isAdmin() || isGestor();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // =========================================================================
    // 4. REGRA RESIDUAL (COLEÇÕES NÃO LISTADAS ACIMA)
    // =========================================================================
    match /{document=**} {
      allow read, write: if false; // BLINDAGEM: Fechar coleções não explicitadas
    }
  }
}
